services:
  app:
    build:
      context: .
    image: medic-resume:local
    
    ports:
      - "3000:3000"
    
    volumes:
      - uploads:/app/data/uploads
      - sqlite-data:/data/db
      - branding:/app/data/branding
    
    environment:
      - NODE_ENV=${NODE_ENV:-development}
      - HOSTNAME=${HOSTNAME:-0.0.0.0}
      - DATABASE_URL=${DATABASE_URL:-file:/data/db/dev.db}
      - BETTER_AUTH_URL=${BETTER_AUTH_URL:-http://localhost:3000}
      - BETTER_AUTH_SECRET=${BETTER_AUTH_SECRET:-dev_secret_32_chars_minimum_len_example}
      - JIRA_BASE_URL=${JIRA_BASE_URL:-}
      - JIRA_EMAIL=${JIRA_EMAIL:-}
      - JIRA_API_TOKEN=${JIRA_API_TOKEN:-}
      - JIRA_PROJECT_KEY=${JIRA_PROJECT_KEY:-EITATI}
      # Healthcheck configuration
      - HEALTHCHECK_INTERVAL=${HEALTHCHECK_INTERVAL:-30s}
      - HEALTHCHECK_TIMEOUT=${HEALTHCHECK_TIMEOUT:-10s}
      - HEALTHCHECK_RETRIES=${HEALTHCHECK_RETRIES:-3}
    
    # Resource limits
    deploy:
      resources:
        limits:
          cpus: "1.0"
          memory: 512M
        reservations:
          cpus: "0.5"
          memory: 256M
    
    healthcheck:
      test: ["CMD", "wget", "--spider", "-q", "http://127.0.0.1:3000/api/health"]
      interval: ${HEALTHCHECK_INTERVAL:-30s}
      timeout: ${HEALTHCHECK_TIMEOUT:-10s}
      retries: ${HEALTHCHECK_RETRIES:-3}
    restart: unless-stopped

volumes:
  uploads:
  sqlite-data:
  branding:
